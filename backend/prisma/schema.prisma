// Regulatory Compliance Platform - Prisma Schema
// Production-grade schema for enterprise compliance management

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearch"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  COMPLIANCE_OFFICER
  AUDITOR
  MANAGER
  VIEWER
}

enum RegulationStatus {
  DRAFT
  PROPOSED
  CONSULTATION
  APPROVED
  ENACTED
  EFFECTIVE
  ENFORCED
  AMENDED
  REPEALED
  ARCHIVED
}

enum LifecycleStage {
  IDENTIFICATION
  ASSESSMENT
  IMPLEMENTATION
  MONITORING
  REVIEW
  CLOSED
}

enum ImpactLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  NEGLIGIBLE
}

enum ProjectStatus {
  NOT_STARTED
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum AuditType {
  COMPLIANCE
  INTERNAL
  EXTERNAL
  INSPECTION
  SURVEILLANCE
}

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  FIELDWORK
  REPORTING
  COMPLETED
  CANCELLED
}

enum FindingSeverity {
  CRITICAL
  MAJOR
  MINOR
  OBSERVATION
  OPPORTUNITY
}

enum FindingStatus {
  OPEN
  IN_PROGRESS
  REMEDIATED
  VERIFIED
  CLOSED
  ACCEPTED
}

enum CAPAType {
  CORRECTIVE
  PREVENTIVE
}

enum CAPAStatus {
  OPEN
  IN_PROGRESS
  IMPLEMENTED
  VERIFIED
  CLOSED
}

enum DocumentType {
  POLICY
  PROCEDURE
  SOP
  GUIDELINE
  TEMPLATE
  FORM
  REPORT
  CONTRACT
  CERTIFICATE
  OTHER
}

enum DocumentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  EXPIRED
  ARCHIVED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  RECALLED
}

enum NotificationType {
  REGULATION_UPDATE
  TASK_ASSIGNED
  TASK_OVERDUE
  AUDIT_SCHEDULED
  DOCUMENT_EXPIRING
  APPROVAL_REQUIRED
  SYSTEM_ALERT
  AI_RECOMMENDATION
}

enum WorkflowTrigger {
  REGULATION_ADDED
  REGULATION_UPDATED
  DEADLINE_APPROACHING
  ACTION_OVERDUE
  RISK_THRESHOLD
  POLICY_EXPIRING
  AUDIT_DUE
}

enum RiskLikelihood {
  RARE
  UNLIKELY
  POSSIBLE
  LIKELY
  ALMOST_CERTAIN
}

enum RiskConsequence {
  INSIGNIFICANT
  MINOR
  MODERATE
  MAJOR
  CATASTROPHIC
}

enum RAGStatus {
  RED
  AMBER
  GREEN
}

enum EvidenceType {
  DOCUMENT
  SCREENSHOT
  EMAIL
  MEETING_MINUTES
  SIGN_OFF
  TEST_RESULT
  CERTIFICATE
  OTHER
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String
  cognitoId   String?  @unique @map("cognito_id")
  role        UserRole @default(VIEWER)
  avatar      String?
  department  String?
  jobTitle    String?  @map("job_title")
  phone       String?
  timezone    String   @default("UTC")
  lastLoginAt DateTime? @map("last_login_at")
  preferences Json?    @default("{}")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations - entities owned by this user
  ownedRegulations     Regulation[]       @relation("RegulationOwner")
  ownedObligations     Obligation[]       @relation("ObligationOwner")
  ownedProjects        Project[]          @relation("ProjectOwner")
  assignedTasks        Task[]             @relation("TaskAssignee")
  reportedTasks        Task[]             @relation("TaskReporter")
  ledAudits            Audit[]            @relation("AuditLeadAuditor")
  ownedFindings        Finding[]          @relation("FindingOwner")
  ownedCAPAs           CAPA[]             @relation("CAPAOwner")
  verifiedCAPAs        CAPA[]             @relation("CAPAVerifier")
  ownedPolicies        Policy[]           @relation("PolicyOwner")
  ownedDocuments       Document[]         @relation("DocumentOwner")
  uploadedEvidence     EvidenceFile[]     @relation("EvidenceUploader")
  ownedRisks           Risk[]             @relation("RiskOwner")
  ownedControls        Control[]          @relation("ControlOwner")
  headOfBusinessAreas  BusinessArea[]     @relation("BusinessAreaHead")
  notifications        Notification[]
  ownedWorkflows       Workflow[]         @relation("WorkflowOwner")
  aiLogs               AILog[]
  promptHistories      PromptHistory[]
  activityLogs         ActivityLog[]
  assessmentsPerformed ImpactAssessment[] @relation("Assessor")
  assessmentsApproved  ImpactAssessment[] @relation("Approver")
  approvalRequests     ApprovalWorkflow[] @relation("ApprovalRequester")
  approvalDecisions    ApprovalWorkflow[] @relation("ApprovalDecider")
  systemSettingUpdates SystemSetting[]    @relation("SettingUpdater")

  @@index([email])
  @@index([cognitoId])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Country {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique /// ISO 3166-1 alpha-2 country code
  region    String?
  subRegion String?  @map("sub_region")
  isActive  Boolean  @default(true) @map("is_active")
  flagEmoji String?  @map("flag_emoji")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  regulators  Regulator[]
  regulations Regulation[]
  suppliers   Supplier[]

  @@index([code])
  @@index([region])
  @@map("countries")
}

model Regulator {
  id           String   @id @default(uuid())
  name         String
  abbreviation String?
  countryId    String   @map("country_id")
  website      String?
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  country     Country      @relation(fields: [countryId], references: [id])
  regulations Regulation[]

  @@index([countryId])
  @@map("regulators")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  color       String?
  icon        String?
  parentId    String?  @map("parent_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent      Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[]   @relation("CategoryHierarchy")
  regulations Regulation[]
  risks       Risk[]

  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

model BusinessArea {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  color       String?
  headUserId  String?  @map("head_user_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  head                    User?                    @relation("BusinessAreaHead", fields: [headUserId], references: [id])
  regulations             RegulationBusinessArea[]
  obligations             Obligation[]
  audits                  Audit[]
  policies                Policy[]
  risks                   Risk[]
  controls                Control[]
  trainingRequirements    TrainingRequirement[]

  @@index([slug])
  @@index([headUserId])
  @@map("business_areas")
}

model Regulation {
  id                   String           @id @default(uuid())
  title                String
  slug                 String           @unique
  summary              String?          @db.Text
  description          String?          @db.Text
  countryId            String           @map("country_id")
  regulatorId          String?          @map("regulator_id")
  industrySector       String?          @map("industry_sector")
  categoryId           String?          @map("category_id")
  keywords             String[]
  sourceUrl            String?          @map("source_url")
  lifecycleStage       LifecycleStage   @default(IDENTIFICATION) @map("lifecycle_stage")
  consultationStartDate DateTime?       @map("consultation_start_date")
  consultationEndDate  DateTime?        @map("consultation_end_date")
  approvalDate         DateTime?        @map("approval_date")
  effectiveDate        DateTime?        @map("effective_date")
  enforcementDate      DateTime?        @map("enforcement_date")
  reviewDate           DateTime?        @map("review_date")
  status               RegulationStatus @default(DRAFT)
  impactLevel          ImpactLevel?     @map("impact_level")
  costImpact           Decimal?         @map("cost_impact") @db.Decimal(18, 2)
  operationalImpact    ImpactLevel?     @map("operational_impact")
  legalImpact          ImpactLevel?     @map("legal_impact")
  reputationImpact     ImpactLevel?     @map("reputation_impact")
  esgImpact            ImpactLevel?     @map("esg_impact")

  /// AI-generated summary of the regulation
  aiSummary            String?          @map("ai_summary") @db.Text
  /// AI-extracted obligations in structured JSON format
  aiObligations        Json?            @map("ai_obligations")
  /// AI-assessed business impact analysis
  aiBusinessImpacts    Json?            @map("ai_business_impacts")
  /// AI-generated compliance recommendations
  aiRecommendations    Json?            @map("ai_recommendations")
  /// Confidence score of AI analysis (0.0 - 1.0)
  aiConfidenceScore    Float?           @map("ai_confidence_score")

  ownerId              String           @map("owner_id")
  ragStatus            RAGStatus?       @map("rag_status")
  notes                String?          @db.Text
  metadata             Json?
  isArchived           Boolean          @default(false) @map("is_archived")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  country              Country                  @relation(fields: [countryId], references: [id])
  regulator            Regulator?               @relation(fields: [regulatorId], references: [id])
  category             Category?                @relation(fields: [categoryId], references: [id])
  owner                User                     @relation("RegulationOwner", fields: [ownerId], references: [id])
  obligations          Obligation[]
  impactAssessments    ImpactAssessment[]
  sources              RegulationSource[]
  projects             Project[]
  audits               Audit[]
  evidenceFiles        EvidenceFile[]
  promptHistories      PromptHistory[]
  businessAreas        RegulationBusinessArea[]
  policies             RegulationPolicy[]
  risks                RegulationRisk[]
  trainingRequirements TrainingRequirement[]

  @@index([slug])
  @@index([countryId])
  @@index([regulatorId])
  @@index([categoryId])
  @@index([ownerId])
  @@index([status])
  @@index([lifecycleStage])
  @@index([impactLevel])
  @@index([effectiveDate])
  @@index([isArchived])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([summary(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("regulations")
}

model RegulationSource {
  id             String   @id @default(uuid())
  regulationId   String   @map("regulation_id")
  name           String
  url            String?
  documentFileId String?  @map("document_file_id")
  uploadedAt     DateTime? @map("uploaded_at")
  createdAt      DateTime @default(now()) @map("created_at")

  regulation   Regulation    @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  documentFile EvidenceFile? @relation(fields: [documentFileId], references: [id])

  @@index([regulationId])
  @@map("regulation_sources")
}

model Obligation {
  id             String       @id @default(uuid())
  regulationId   String       @map("regulation_id")
  title          String
  description    String?      @db.Text
  requirement    String?      @db.Text
  dueDate        DateTime?    @map("due_date")
  ownerId        String?      @map("owner_id")
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  businessAreaId String?      @map("business_area_id")
  /// References to Control IDs for traceability mapping
  controlIds     String[]     @map("control_ids")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  regulation   Regulation         @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  owner        User?              @relation("ObligationOwner", fields: [ownerId], references: [id])
  businessArea BusinessArea?      @relation(fields: [businessAreaId], references: [id])
  controls     ControlObligation[]

  @@index([regulationId])
  @@index([ownerId])
  @@index([businessAreaId])
  @@index([status])
  @@index([dueDate])
  @@map("obligations")
}

model ImpactAssessment {
  id                 String        @id @default(uuid())
  regulationId       String        @map("regulation_id")
  assessorId         String        @map("assessor_id")
  overallImpact      ImpactLevel
  costEstimate       Decimal?      @map("cost_estimate") @db.Decimal(18, 2)
  timelineEstimate   String?       @map("timeline_estimate")
  departmentImpacts  Json?         @map("department_impacts")
  policyImpacts      Json?         @map("policy_impacts")
  controlMapping     Json?         @map("control_mapping")
  trainingImpacts    Json?         @map("training_impacts")
  supplierImpacts    Json?         @map("supplier_impacts")
  gapAnalysis        Json?         @map("gap_analysis")
  residualRiskScore  Float?        @map("residual_risk_score")
  riskAccepted       Boolean       @default(false) @map("risk_accepted")
  approvalStatus     ApprovalStatus @default(PENDING) @map("approval_status")
  approvedById       String?       @map("approved_by_id")
  approvedAt         DateTime?     @map("approved_at")
  notes              String?       @db.Text
  aiAssisted         Boolean       @default(false) @map("ai_assisted")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  regulation Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  assessor   User       @relation("Assessor", fields: [assessorId], references: [id])
  approvedBy User?      @relation("Approver", fields: [approvedById], references: [id])

  @@index([regulationId])
  @@index([assessorId])
  @@index([approvalStatus])
  @@map("impact_assessments")
}

model Project {
  id           String        @id @default(uuid())
  title        String
  slug         String        @unique
  description  String?       @db.Text
  regulationId String?       @map("regulation_id")
  status       ProjectStatus @default(NOT_STARTED)
  ownerId      String        @map("owner_id")
  startDate    DateTime?     @map("start_date")
  endDate      DateTime?     @map("end_date")
  budget       Decimal?      @db.Decimal(18, 2)
  spent        Decimal?      @default(0) @db.Decimal(18, 2)
  progress     Float         @default(0)
  ragStatus    RAGStatus?    @map("rag_status")
  riskLog      Json?         @map("risk_log")
  issuesLog    Json?         @map("issues_log")
  decisionsLog Json?         @map("decisions_log")
  stakeholders Json?
  isArchived   Boolean       @default(false) @map("is_archived")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  regulation      Regulation?     @relation(fields: [regulationId], references: [id])
  owner           User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  tasks           Task[]
  milestones      Milestone[]
  evidenceFiles   EvidenceFile[]
  audits          Audit[]
  promptHistories PromptHistory[]

  @@index([slug])
  @@index([regulationId])
  @@index([ownerId])
  @@index([status])
  @@index([isArchived])
  @@map("projects")
}

model Milestone {
  id            String        @id @default(uuid())
  projectId     String        @map("project_id")
  title         String
  description   String?       @db.Text
  dueDate       DateTime?     @map("due_date")
  completedDate DateTime?     @map("completed_date")
  status        ProjectStatus @default(NOT_STARTED)
  order         Int           @default(0)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([dueDate])
  @@map("milestones")
}

model Task {
  id               String       @id @default(uuid())
  title            String
  description      String?      @db.Text
  projectId        String?      @map("project_id")
  assigneeId       String?      @map("assignee_id")
  reporterId       String?      @map("reporter_id")
  status           TaskStatus   @default(TODO)
  priority         TaskPriority @default(MEDIUM)
  dueDate          DateTime?    @map("due_date")
  startDate        DateTime?    @map("start_date")
  completedDate    DateTime?    @map("completed_date")
  estimatedHours   Float?       @map("estimated_hours")
  actualHours      Float?       @map("actual_hours")
  parentTaskId     String?      @map("parent_task_id")
  order            Int          @default(0)
  tags             String[]
  isRecurring      Boolean      @default(false) @map("is_recurring")
  recurringPattern Json?        @map("recurring_pattern")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  project       Project?         @relation(fields: [projectId], references: [id])
  assignee      User?            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporter      User?            @relation("TaskReporter", fields: [reporterId], references: [id])
  parentTask    Task?            @relation("TaskSubtasks", fields: [parentTaskId], references: [id])
  subtasks      Task[]           @relation("TaskSubtasks")
  evidenceFiles EvidenceFile[]
  dependsOn     TaskDependency[] @relation("DependentTask")
  dependedOnBy  TaskDependency[] @relation("DependencyTarget")

  @@index([projectId])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([parentTaskId])
  @@map("tasks")
}

model TaskDependency {
  id             String   @id @default(uuid())
  taskId         String   @map("task_id")
  dependsOnTaskId String  @map("depends_on_task_id")
  /// Dependency type: FS (Finish-to-Start), FF (Finish-to-Finish), SS (Start-to-Start), SF (Start-to-Finish)
  type           String   @default("FS")
  createdAt      DateTime @default(now()) @map("created_at")

  task      Task @relation("DependentTask", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("DependencyTarget", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@index([taskId])
  @@index([dependsOnTaskId])
  @@map("task_dependencies")
}

model Audit {
  id                   String      @id @default(uuid())
  title                String
  description          String?     @db.Text
  type                 AuditType   @default(COMPLIANCE)
  status               AuditStatus @default(PLANNED)
  leadAuditorId        String      @map("lead_auditor_id")
  regulationId         String?     @map("regulation_id")
  projectId            String?     @map("project_id")
  businessAreaId       String?     @map("business_area_id")
  scope                String?     @db.Text
  objectives           String?     @db.Text
  methodology          String?     @db.Text
  startDate            DateTime?   @map("start_date")
  endDate              DateTime?   @map("end_date")
  fieldworkStartDate   DateTime?   @map("fieldwork_start_date")
  fieldworkEndDate     DateTime?   @map("fieldwork_end_date")
  reportDueDate        DateTime?   @map("report_due_date")
  readinessScore       Float?      @map("readiness_score")
  /// AI-generated audit questions based on regulation scope
  aiGeneratedQuestions Json?       @map("ai_generated_questions")
  /// AI-generated interview guide for audit fieldwork
  aiInterviewGuide     Json?       @map("ai_interview_guide")
  /// AI-generated compliance checklist
  aiChecklist          Json?       @map("ai_checklist")
  isRecurring          Boolean     @default(false) @map("is_recurring")
  recurringPattern     Json?       @map("recurring_pattern")
  nextAuditDate        DateTime?   @map("next_audit_date")
  programme            Json?
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  leadAuditor     User            @relation("AuditLeadAuditor", fields: [leadAuditorId], references: [id])
  regulation      Regulation?     @relation(fields: [regulationId], references: [id])
  project         Project?        @relation(fields: [projectId], references: [id])
  businessArea    BusinessArea?   @relation(fields: [businessAreaId], references: [id])
  findings        Finding[]
  evidenceFiles   EvidenceFile[]
  promptHistories PromptHistory[]

  @@index([leadAuditorId])
  @@index([regulationId])
  @@index([projectId])
  @@index([businessAreaId])
  @@index([status])
  @@index([type])
  @@index([startDate])
  @@map("audits")
}

model Finding {
  id                String          @id @default(uuid())
  auditId           String          @map("audit_id")
  title             String
  description       String?         @db.Text
  severity          FindingSeverity @default(MINOR)
  status            FindingStatus   @default(OPEN)
  rootCause         String?         @map("root_cause") @db.Text
  recommendation    String?         @db.Text
  managementResponse String?        @map("management_response") @db.Text
  ownerId           String?         @map("owner_id")
  dueDate           DateTime?       @map("due_date")
  closedDate        DateTime?       @map("closed_date")
  evidenceRequired  Boolean         @default(false) @map("evidence_required")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  audit  Audit  @relation(fields: [auditId], references: [id], onDelete: Cascade)
  owner  User?  @relation("FindingOwner", fields: [ownerId], references: [id])
  capas  CAPA[]

  @@index([auditId])
  @@index([ownerId])
  @@index([severity])
  @@index([status])
  @@index([dueDate])
  @@map("findings")
}

model CAPA {
  id                 String     @id @default(uuid())
  findingId          String     @map("finding_id")
  title              String
  description        String?    @db.Text
  type               CAPAType
  status             CAPAStatus @default(OPEN)
  ownerId            String     @map("owner_id")
  dueDate            DateTime?  @map("due_date")
  completedDate      DateTime?  @map("completed_date")
  verifiedById       String?    @map("verified_by_id")
  verifiedDate       DateTime?  @map("verified_date")
  rootCauseAnalysis  String?    @map("root_cause_analysis") @db.Text
  actionPlan         String?    @map("action_plan") @db.Text
  effectivenessCheck String?    @map("effectiveness_check") @db.Text
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  finding    Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  owner      User    @relation("CAPAOwner", fields: [ownerId], references: [id])
  verifiedBy User?   @relation("CAPAVerifier", fields: [verifiedById], references: [id])

  @@index([findingId])
  @@index([ownerId])
  @@index([status])
  @@index([dueDate])
  @@map("capas")
}

model Policy {
  id              String         @id @default(uuid())
  title           String
  slug            String         @unique
  description     String?        @db.Text
  type            DocumentType   @default(POLICY)
  status          DocumentStatus @default(DRAFT)
  version         Int            @default(1)
  currentVersion  String?        @map("current_version")
  content         String?        @db.Text
  ownerId         String         @map("owner_id")
  businessAreaId  String?        @map("business_area_id")
  effectiveDate   DateTime?      @map("effective_date")
  expiryDate      DateTime?      @map("expiry_date")
  reviewDate      DateTime?      @map("review_date")
  approvalHistory Json?          @map("approval_history")
  metadata        Json?
  tags            String[]
  isArchived      Boolean        @default(false) @map("is_archived")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  owner        User               @relation("PolicyOwner", fields: [ownerId], references: [id])
  businessArea BusinessArea?      @relation(fields: [businessAreaId], references: [id])
  regulations  RegulationPolicy[]

  @@index([slug])
  @@index([ownerId])
  @@index([businessAreaId])
  @@index([status])
  @@index([expiryDate])
  @@index([reviewDate])
  @@map("policies")
}

model Document {
  id           String         @id @default(uuid())
  title        String
  description  String?        @db.Text
  type         DocumentType   @default(OTHER)
  status       DocumentStatus @default(DRAFT)
  version      Int            @default(1)
  filePath     String?        @map("file_path")
  fileSize     BigInt?        @map("file_size")
  mimeType     String?        @map("mime_type")
  ownerId      String         @map("owner_id")
  /// Full-text content extracted via OCR
  ocrContent   String?        @map("ocr_content") @db.Text
  ocrProcessed Boolean        @default(false) @map("ocr_processed")
  metadata     Json?
  tags         String[]
  expiryDate   DateTime?      @map("expiry_date")
  reviewDate   DateTime?      @map("review_date")
  isArchived   Boolean        @default(false) @map("is_archived")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  owner User @relation("DocumentOwner", fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([type])
  @@index([status])
  @@index([expiryDate])
  @@map("documents")
}

model EvidenceFile {
  id           String       @id @default(uuid())
  name         String
  description  String?      @db.Text
  type         EvidenceType @default(DOCUMENT)
  filePath     String       @map("file_path")
  fileSize     BigInt?      @map("file_size")
  mimeType     String?      @map("mime_type")
  uploadedById String       @map("uploaded_by_id")
  regulationId String?      @map("regulation_id")
  projectId    String?      @map("project_id")
  auditId      String?      @map("audit_id")
  taskId       String?      @map("task_id")
  /// Full-text content extracted via OCR
  ocrContent   String?      @map("ocr_content") @db.Text
  ocrProcessed Boolean      @default(false) @map("ocr_processed")
  metadata     Json?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  uploadedBy        User               @relation("EvidenceUploader", fields: [uploadedById], references: [id])
  regulation        Regulation?        @relation(fields: [regulationId], references: [id])
  project           Project?           @relation(fields: [projectId], references: [id])
  audit             Audit?             @relation(fields: [auditId], references: [id])
  task              Task?              @relation(fields: [taskId], references: [id])
  regulationSources RegulationSource[]

  @@index([uploadedById])
  @@index([regulationId])
  @@index([projectId])
  @@index([auditId])
  @@index([taskId])
  @@index([type])
  @@map("evidence_files")
}

model Risk {
  id             String          @id @default(uuid())
  title          String
  description    String?         @db.Text
  categoryId     String?         @map("category_id")
  businessAreaId String?         @map("business_area_id")
  ownerId        String          @map("owner_id")
  likelihood     RiskLikelihood  @default(POSSIBLE)
  consequence    RiskConsequence @default(MODERATE)
  inherentScore  Float?          @map("inherent_score")
  residualScore  Float?          @map("residual_score")
  riskAppetite   Float?          @map("risk_appetite")
  mitigationPlan String?         @map("mitigation_plan") @db.Text
  status         RAGStatus?
  reviewDate     DateTime?       @map("review_date")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  category     Category?        @relation(fields: [categoryId], references: [id])
  businessArea BusinessArea?    @relation(fields: [businessAreaId], references: [id])
  owner        User             @relation("RiskOwner", fields: [ownerId], references: [id])
  controls     RiskControl[]
  regulations  RegulationRisk[]

  @@index([categoryId])
  @@index([businessAreaId])
  @@index([ownerId])
  @@index([likelihood])
  @@index([consequence])
  @@index([isActive])
  @@map("risks")
}

model Control {
  id             String    @id @default(uuid())
  title          String
  description    String?   @db.Text
  type           String?
  ownerId        String    @map("owner_id")
  businessAreaId String?   @map("business_area_id")
  effectiveness  Float?
  lastTestedDate DateTime? @map("last_tested_date")
  nextTestDate   DateTime? @map("next_test_date")
  testFrequency  String?   @map("test_frequency")
  isAutomated    Boolean   @default(false) @map("is_automated")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  owner        User                @relation("ControlOwner", fields: [ownerId], references: [id])
  businessArea BusinessArea?       @relation(fields: [businessAreaId], references: [id])
  risks        RiskControl[]
  obligations  ControlObligation[]

  @@index([ownerId])
  @@index([businessAreaId])
  @@index([isActive])
  @@index([nextTestDate])
  @@map("controls")
}

model Supplier {
  id                String      @id @default(uuid())
  name              String
  description       String?     @db.Text
  contactName       String?     @map("contact_name")
  contactEmail      String?     @map("contact_email")
  website           String?
  countryId         String?     @map("country_id")
  riskLevel         ImpactLevel? @map("risk_level")
  contractStartDate DateTime?   @map("contract_start_date")
  contractEndDate   DateTime?   @map("contract_end_date")
  reviewDate        DateTime?   @map("review_date")
  status            String?
  isActive          Boolean     @default(true) @map("is_active")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  country Country? @relation(fields: [countryId], references: [id])

  @@index([countryId])
  @@index([riskLevel])
  @@index([isActive])
  @@map("suppliers")
}

model TrainingRequirement {
  id               String   @id @default(uuid())
  title            String
  description      String?  @db.Text
  regulationId     String?  @map("regulation_id")
  businessAreaId   String?  @map("business_area_id")
  targetAudience   String?  @map("target_audience")
  dueDate          DateTime? @map("due_date")
  completedDate    DateTime? @map("completed_date")
  status           TaskStatus @default(TODO)
  isRecurring      Boolean  @default(false) @map("is_recurring")
  recurringPattern Json?    @map("recurring_pattern")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  regulation   Regulation?   @relation(fields: [regulationId], references: [id])
  businessArea BusinessArea? @relation(fields: [businessAreaId], references: [id])

  @@index([regulationId])
  @@index([businessAreaId])
  @@index([status])
  @@index([dueDate])
  @@map("training_requirements")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String           @db.Text
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([userId, isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model Workflow {
  id            String          @id @default(uuid())
  name          String
  description   String?         @db.Text
  trigger       WorkflowTrigger
  conditions    Json?
  actions       Json?
  isActive      Boolean         @default(true) @map("is_active")
  ownerId       String          @map("owner_id")
  lastTriggered DateTime?       @map("last_triggered")
  triggerCount  Int             @default(0) @map("trigger_count")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  owner      User                @relation("WorkflowOwner", fields: [ownerId], references: [id])
  executions WorkflowExecution[]

  @@index([trigger])
  @@index([isActive])
  @@index([ownerId])
  @@map("workflows")
}

model WorkflowExecution {
  id          String    @id @default(uuid())
  workflowId  String    @map("workflow_id")
  triggeredBy String?   @map("triggered_by")
  input       Json?
  output      Json?
  status      String
  error       String?   @db.Text
  startedAt   DateTime  @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([status])
  @@index([startedAt])
  @@map("workflow_executions")
}

/// Append-only log of all AI API calls for cost tracking and auditing
model AILog {
  id               String   @id @default(uuid())
  userId           String?  @map("user_id")
  action           String
  model            String
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")
  cost             Decimal? @db.Decimal(10, 6)
  inputRedacted    Boolean  @default(false) @map("input_redacted")
  prompt           String?  @db.Text
  response         String?  @db.Text
  metadata         Json?
  latency          Int?     /// Response latency in milliseconds
  createdAt        DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([model])
  @@index([createdAt])
  @@map("ai_logs")
}

model PromptHistory {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  query        String   @db.Text
  response     String?  @db.Text
  context      Json?
  regulationId String?  @map("regulation_id")
  projectId    String?  @map("project_id")
  auditId      String?  @map("audit_id")
  feedback     String?
  createdAt    DateTime @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id])
  regulation Regulation? @relation(fields: [regulationId], references: [id])
  project    Project?    @relation(fields: [projectId], references: [id])
  audit      Audit?      @relation(fields: [auditId], references: [id])

  @@index([userId])
  @@index([regulationId])
  @@index([projectId])
  @@index([auditId])
  @@index([createdAt])
  @@map("prompt_histories")
}

/// Append-only immutable audit trail of all user actions
model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  changes    Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@index([entityType])
  @@map("activity_logs")
}

model ApprovalWorkflow {
  id            String         @id @default(uuid())
  entityType    String         @map("entity_type")
  entityId      String         @map("entity_id")
  requestedById String         @map("requested_by_id")
  approverId    String?        @map("approver_id")
  status        ApprovalStatus @default(PENDING)
  comments      String?        @db.Text
  requestedAt   DateTime       @map("requested_at")
  respondedAt   DateTime?      @map("responded_at")
  createdAt     DateTime       @default(now()) @map("created_at")

  requestedBy User  @relation("ApprovalRequester", fields: [requestedById], references: [id])
  approver    User? @relation("ApprovalDecider", fields: [approverId], references: [id])

  @@index([entityType, entityId])
  @@index([requestedById])
  @@index([approverId])
  @@index([status])
  @@map("approval_workflows")
}

/// Stores pre-computed search content and vector embeddings for semantic search
model SearchIndex {
  id         String                          @id @default(uuid())
  entityType String                          @map("entity_type")
  entityId   String                          @map("entity_id")
  content    String                          @db.Text
  metadata   Json?
  /// Placeholder for pgvector embedding — enable pgvector extension in production
  /// embedding  Unsupported("vector(1536)")?
  indexedAt   DateTime                       @map("indexed_at")
  createdAt   DateTime                       @default(now()) @map("created_at")
  updatedAt   DateTime                       @updatedAt @map("updated_at")

  @@unique([entityType, entityId])
  @@index([entityType])
  @@index([entityType, entityId])
  @@map("search_indexes")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedBy User? @relation("SettingUpdater", fields: [updatedById], references: [id])

  @@index([key])
  @@map("system_settings")
}

// ─────────────────────────────────────────────
// MANY-TO-MANY JOIN TABLES
// ─────────────────────────────────────────────

model RegulationBusinessArea {
  id             String   @id @default(uuid())
  regulationId   String   @map("regulation_id")
  businessAreaId String   @map("business_area_id")
  createdAt      DateTime @default(now()) @map("created_at")

  regulation   Regulation   @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  businessArea BusinessArea @relation(fields: [businessAreaId], references: [id], onDelete: Cascade)

  @@unique([regulationId, businessAreaId])
  @@index([regulationId])
  @@index([businessAreaId])
  @@map("regulation_business_areas")
}

model RegulationPolicy {
  id           String   @id @default(uuid())
  regulationId String   @map("regulation_id")
  policyId     String   @map("policy_id")
  createdAt    DateTime @default(now()) @map("created_at")

  regulation Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  policy     Policy     @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([regulationId, policyId])
  @@index([regulationId])
  @@index([policyId])
  @@map("regulation_policies")
}

model RegulationRisk {
  id           String   @id @default(uuid())
  regulationId String   @map("regulation_id")
  riskId       String   @map("risk_id")
  createdAt    DateTime @default(now()) @map("created_at")

  regulation Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  risk       Risk       @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@unique([regulationId, riskId])
  @@index([regulationId])
  @@index([riskId])
  @@map("regulation_risks")
}

model RiskControl {
  id        String   @id @default(uuid())
  riskId    String   @map("risk_id")
  controlId String   @map("control_id")
  createdAt DateTime @default(now()) @map("created_at")

  risk    Risk    @relation(fields: [riskId], references: [id], onDelete: Cascade)
  control Control @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@unique([riskId, controlId])
  @@index([riskId])
  @@index([controlId])
  @@map("risk_controls")
}

model ControlObligation {
  id           String   @id @default(uuid())
  controlId    String   @map("control_id")
  obligationId String   @map("obligation_id")
  createdAt    DateTime @default(now()) @map("created_at")

  control    Control    @relation(fields: [controlId], references: [id], onDelete: Cascade)
  obligation Obligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)

  @@unique([controlId, obligationId])
  @@index([controlId])
  @@index([obligationId])
  @@map("control_obligations")
}
