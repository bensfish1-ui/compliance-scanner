# ═══════════════════════════════════════════════════════════
# Compliance Scanner Backend - Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════

# Application
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000

# PostgreSQL Database (with pgvector extension)
DATABASE_URL=postgresql://compliance:compliance@localhost:5432/compliance_scanner?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AWS Credentials
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# AWS S3 (use LocalStack endpoint for local development)
AWS_S3_BUCKET=compliance-scanner-documents
AWS_S3_ENDPOINT=http://localhost:4566

# AWS Cognito
AWS_COGNITO_USER_POOL_ID=eu-west-2_XXXXXXXXX
AWS_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_COGNITO_REGION=eu-west-2

# AWS SES
AWS_SES_FROM_EMAIL=noreply@compliancescanner.io
AWS_SES_REGION=eu-west-2

# OpenAI
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# OpenSearch
OPENSEARCH_NODE=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_INDEX_PREFIX=compliance

# JWT (internal, Cognito handles primary auth)
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=24h

# Integrations (optional)
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# Upload
MAX_FILE_SIZE=52428800
ALLOWED_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/png,image/jpeg,text/csv,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# Logging
LOG_LEVEL=debug
